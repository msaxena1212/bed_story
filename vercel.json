{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/generate-story", "dest": "api/index.py" },
    { "src": "/generate-audio", "dest": "api/index.py" },
    { "src": "/stories", "dest": "api/index.py" },
    { "src": "/save-story", "dest": "api/index.py" },
    { "src": "/(.*)", "dest": "frontend/$1" }
  ]
}
